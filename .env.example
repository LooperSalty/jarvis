# Nom sous lequel Jarvis s'adresse a toi (defaut : Monsieur)
JARVIS_USER_NAME=Monsieur

# Cles API (toutes optionnelles : sans cle, Jarvis bascule en mode 100% local Ollama)
GEMINI_API_KEY=VOTRE_API
YOUTUBE_API_KEY=VOTRE_API
HA_TOKEN=VOTRE_API
HA_URL=https://URL-Home-assistant
XAI_API_KEY=VOTRE_API
SERPAPI_API_KEY=VOTRE_API
GROQ_API_KEY=VOTRE_API

# Vault Obsidian (auto-detecte si Documents/Obsidian Vault/ existe)
# OBSIDIAN_VAULT=C:\Users\<toi>\Documents\Obsidian Vault

# Meross : controle des prises Wi-Fi (MSS710 etc.) via "lumiere", "allume la lampe", "eteins"
# Pour activer : decommente + mets tes identifiants Meross (compte mobile app)
# MEROSS_EMAIL=ton.email@exemple.com
# MEROSS_PASSWORD=tonMotDePasse
# Region serveur (defaut Europe). US: iotx-us.meross.com / Asie: iotx-ap.meross.com
# MEROSS_API_BASE=https://iotx-eu.meross.com

# Forcer le mode local Ollama meme si Gemini est dispo
# FORCE_OLLAMA=1

# Seuil d'inactivite Claude Code avant notification vocale (jours)
CLAUDE_INACTIVITE_SEUIL_JOURS=3
