# Secrets et configuration personnelle
.env
.env.*
!.env.example
credentials.json
token.json
token.bin
*.token

# Config Home Assistant perso (entites reelles). Modele : jarvis_home_config_example.py
jarvis_home_config.py

# Memoire et historique perso de Jarvis
jarvis_memoire.json
jarvis_historique.json

# Index vectoriel local de la memoire (RAG via embeddings Ollama, regenerable)
jarvis_memoire_vec.db

# Profil utilisateur (donnees perso : famille, adresse, habitudes).
# Modele : examples/jarvis_profile_example.json
jarvis_profile.json

# Config MCP perso (peut contenir des chemins/env locaux). Modele : examples/jarvis_mcp_example.json
jarvis_mcp.json

# Config UI perso (theme, couleur de l'orbe, dossier Cowork local).
# Modele : examples/jarvis_ui_config_example.json
jarvis_ui_config.json

# Routines programmees et triggers contextuels (prefs locales).
# Modeles : examples/jarvis_routines_example.json / examples/jarvis_triggers_example.json
jarvis_routines.json
jarvis_triggers.json

# Config Operator perso (societe, compteur devis) + etat runtime (journal, file
# d'approbation). Modele : examples/jarvis_operator_example.json
jarvis_operator.json
jarvis_operator_report.json
jarvis_operator_approvals.json

# Token d'appairage WebSocket local (genere auto, non versionne).
# Sert a authentifier les clients distants (mobile/LAN). Voir jarvis_security.py
jarvis_ws_token.txt

# Cache du token OAuth Spotify (genere auto par spotipy, non versionne).
.spotify_cache

# Etat actif/inactif des skills (pref locale)
jarvis_skills/skills_config.json

# Logs et artefacts d'execution
*.log
*.log.err
jarvis_tts_*.mp3
*.mp3
*.wav

# Captures et artefacts temporaires
_orb_v*.png
_screenshot_*.py
_check.py

# Icones generees
jarvis_tray.ico

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Frontend Node
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/*.tsbuildinfo

# Sous-projets externes (autre repo)
OpenJarvis-main/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
desktop.ini
.DS_Store

# Build PyInstaller (artefacts ignores, specs versionnes)
build/
dist/
*.spec
!Jarvis.spec
!JarvisWeb.spec
!model_advisor/ModelAdvisor.spec
# .exe trop lourds pour git (regenerable via build_all.bat)
*.exe
# Dossiers de contenu PyInstaller onedir deverses a la racine par build_all.bat
# (Jarvis.exe + _internal\ , JarvisWeb.exe + _internal_web\). Regenerables.
/_internal/
/_internal_web/
apprendre/dataset_propre.jsonl
apprendre/_learn_state.json
apprendre/prompt_actif.txt
apprendre/prompt_optimise.txt
apprendre/lora_jarvis/
apprendre/_tinyshakespeare.txt

# Sortie de compilation de l'installateur (regenerable via scripts/build_installer.bat)
installer/output/

# Artefacts Playwright MCP
.playwright-mcp/

# Certificat de signature auto-signe (artefact local)
jarvis_codesign.cer
*.pfx
